# Slidesmith is bring-your-own-keys. The easiest way to configure it is the
# in-app Settings screen — keys are saved to ~/.slidesmith/config.json.
#
# These env vars are optional overrides for self-hosting / headless setups:

# Port the local Slidesmith server listens on (default 8787).
# PORT=8787

# Interface to bind (default 127.0.0.1 — loopback only). The server returns
# your API keys to the Settings UI, so DO NOT expose it to a network unless
# you're behind a firewall and know what you're doing.
# HOST=127.0.0.1

# Where config + the generation queue are stored (default ~/.slidesmith).
# SLIDESMITH_DIR=/path/to/data

# You do NOT need to put API keys here — enter them in Settings instead.
# (post-bridge key for scheduling/posting/analytics, OpenRouter key for the AI.)

# ── Login (Firebase Google sign-in) ──────────────────────────────────────────
# Same auth as superwave-admin (Firebase project orbit-ai-471708). Copy this
# file to .env and fill VITE_FIREBASE_API_KEY with the project's PUBLIC web API
# key (Firebase console → Project settings → General → Your apps → Web app →
# SDK setup → apiKey). The web API key is safe to expose. Vite only reads
# VITE_-prefixed vars, and only at dev-server / build start — restart after edits.
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=orbit-ai-471708.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=orbit-ai-471708

# Email allowlist — comma-separated, case-insensitive. Only these Google
# accounts get past the login screen. Leave unset to use the built-in fallback
# list in src/lib/access.ts. Gates the UI only (see that file's note).
VITE_ALLOWED_EMAILS=founders@superwavelabs.com,teammate@superwavelabs.com

# ── Supabase backend storage (config, queue, library) ────────────────────────
# Required when running the hosted/Supabase-backed build. service_role is SECRET
# and server-only — never prefix it with VITE_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# Server-side API auth: same allowlist (no VITE_ prefix) + Firebase project id.
ALLOWED_EMAILS=founders@superwavelabs.com,teammate@superwavelabs.com
FIREBASE_PROJECT_ID=orbit-ai-471708
